# ── Web3Forms: delivers form submissions to your email ──
# 1. Go to https://web3forms.com
# 2. Enter the email where you want submissions delivered (Contact@momintumtx.com)
# 3. Check that email for your access key (UUID-style string)
# 4. Copy this file to .env.local and paste the key below
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# ── ImgBB: hosts the Sell form's card photos (free) ──
# Submitted photos upload here and arrive in the email as clickable links.
# 1. Go to https://api.imgbb.com → "Get API key" (free account)
# 2. Paste the key below
NEXT_PUBLIC_IMGBB_API_KEY=your-imgbb-key-here

# ── PayPal: online shop checkout ──
# Create a PayPal Business account, then create an app at
# https://developer.paypal.com/dashboard/applications (toggle Live vs Sandbox top-right).
#
# NEXT_PUBLIC_PAYPAL_CLIENT_ID  — the app's Client ID (safe to expose; renders the buttons)
# PAYPAL_CLIENT_ID              — same Client ID value (used by the server)
# PAYPAL_SECRET                 — the app's Secret (KEEP PRIVATE — server only)
# PAYPAL_MODE                   — "live" for real payments, "sandbox" for testing
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_SECRET=your-paypal-secret-here
PAYPAL_MODE=live

# ── Supabase: powers the admin panel (products, orders, login, image storage) ──
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API. Copy the values below.
# 3. NEXT_PUBLIC_* are safe to expose. SERVICE_ROLE_KEY is SECRET — server only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
