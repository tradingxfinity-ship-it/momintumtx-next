# Formspree endpoint for the Sell Your Cards form.
# 1. Create a free account at https://formspree.io
# 2. Create a new form and copy its endpoint URL (looks like https://formspree.io/f/xxxxxxxx)
# 3. Copy this file to .env.local and paste the URL below
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
